# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (URL + service role key also power BB OS lead capture from /api/apply — see bb-os/README.md)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Optional: Stripe Price IDs (or create them dynamically)
STRIPE_SHOOTING_EVAL_PRICE_ID=
STRIPE_COMPLETE_EVAL_PRICE_ID=
STRIPE_MENTORSHIP_PRICE_ID=

# Google Drive API (for video folder creation)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Resend (for admin notification emails + applicant confirmation)
RESEND_API_KEY=

# Google Sheet capture for /apply (see APPLICANTS_SETUP.md)
GOOGLE_SHEET_WEBHOOK_URL=
GOOGLE_SHEET_SECRET=

# Gmail SMTP (for email sequences to prospects)
GMAIL_APP_PASSWORD=

# Vercel Cron (for email sequence automation)
CRON_SECRET=

# SignWell (for contracts)
SIGNWELL_API_KEY=
